@article{prinosPrestonModelEconomic2023,
  title = {The {{Preston Model}}: {{Economic Democracy}}, {{Cooperation}}, and {{Paradoxes}} in {{Organisational}} and {{Social Identification}}},
  author = {Prinos, Ioannis and Manley, Julian},
