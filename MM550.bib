@article{FoundationLowballsCost2009,
  title = {Foundation Low-Balls Cost of Fiber to Anchors, Parties Say},
  year = 2009,
  journal = {Telecommunications Reports},
  volume = {75},
  number = {22},
  pages = {34},
  publisher = {Washington: Aspen Publishers, Inc},
  address = {Washington},
  issn = {0163-9854},
  abstract = {CenturyLink, the company resulting from the CenturyTel-Embarq merger, said that the Gates Foundation cost model "appears to leave out the critical component of backhaul (or middle mile) costs" and that it appears to assume an anchor institution placement that is "substantially different from CenturyLink' s experiences serving rural America. The model assumes an average loop length of 20,000 feet to connect anchor institutions in rural America. In CenturyLink' s experience, however, anchor institutions tend to be located far closer to the fiber access points that are currently deployed in rural areas." Regarding the Gates Foundation's assumption that 80\% of anchor institutions lack fiber, FG said, "If the assumption is active fiber all the way to the premise then the number seems low (the percent lacking fiber is probably much higher) based on FG' s experience." It noted that it doesn't have nationwide survey data, and that its current focus is on the central part of the country. "In Western Nebraska, the middle mile network is almost completely absent, no non-incumbent telco or cableco fiber is available for any use not channeled through those incumbents, and no commercial investment is available for new construction," it added. The National Association of Telecommunications Officers and Advisors submitted several exhibits, including two studies conducted by Andrew Afflerbach of Columbia Telecommunications Corp. One study found "the average, per-site construction cost of connecting anchor institutions to fiber would be \$50,000," and the other found that "the cost of extending underground fiber (including the cost of electronics to operate the fiber and offer services)" from existing government anchor institutions in Prince George's County, Md., to nine community anchor institutions including schools, libraries, fire stations, and government buildings would be \$1.2 million.},
  keywords = {Academic libraries,Charities,Communications networks,Community colleges,Connectivity,Construction costs,Cost estimates,Economic aspects,Fiber optic networks,Fiber optics,Internet,Manycompanies,Public buildings,Rural areas}
}

@incollection{garrickRoleHospitalHealthcare2019,
  title = {The {{Role}} of the {{Hospital}} in the {{Healthcare System}}},
  author = {Garrick, Renee and Sullivan, Janet (Jessie) and Doran, Maureen and Keenan, June},
  editor = {Latifi, Rifat},
  year = 2019,
  pages = {47--60},
  publisher = {Cham: Springer International Publishing},
  address = {Cham},
  doi = {10.1007/978-3-030-01394-3_6},
  abstract = {Ancient hospitals were shelters for the needy. Hospitals continue to provide overnight care for patients too ill to stay home, but advances in science, technology, and training have made modern hospitals not only sites of care but also sites of cure. This chapter focuses on the role of hospitals, particularly Academic Medical Centers, in the US healthcare system. Today patients are less likely to be admitted to the hospital, and those admitted stay a shorter time, while the intensity and cost of the services provided have risen dramatically. Academic Medical Centers play a particularly important role in providing highly technical services based on their tripartite mission to educate students and residents, conduct basic and translational research, and provide direct clinical care. Fewer hospital admissions and competition from free-standing providers of ambulatory services have placed hospitals in an economic squeeze, exacerbated by increased accountability for outcomes during and after hospitalization, and economic pressures to implement technology, expand training, and maintain research while containing costs. In response to these pressures, many previously independent organizations have begun to consolidate into more integrated delivery systems including alliances of larger Academic Medical Centers with community and rural hospitals and primary and specialty care physician practices. To achieve the goals of providing efficient and effective care to populations, these alliances can adopt the models of patient-centered primary care within a network of clinically integrated specialty providers and affiliated hospitals. Hospitals can also play a key role as economic and civic institutions working with other stakeholders to maintain community vitality. In the modern hospital, highly trained professionals provide very technical, intensive services which will remain an essential element of care for some patients ensuring that hospitals will continue to be a critical component of the future healthcare delivery system.},
  keywords = {Academic Medical Center,AI:Hospitals,Anchor institution,Horizontal and vertical integration,Hospital consolidation,Hospital utilization trends,Medical neighborhood,Patient-centered medical home,US healthcare system,Value-based payment},
  file = {/home/darrengarside/snap/zotero-snap/common/Zotero/storage/96FB94ZB/Garrick et al. - 2019 - The Role of the Hospital in the Healthcare System.pdf}
}

@article{gartonUniversityUrbanDevelopment2026,
  title = {University {{Urban Development}} and {{Studentification}}: {{Evidence}} of {{Neighborhood Change Unique}} to {{Higher Education}}},
  author = {Garton, Paul M.},
  year = 2026,
  journal = {Higher education politics \& economics},
  volume = {12},
  number = {1},
  pages = {69},
  publisher = {Open Journals in Education (OJED), STAR Scholars Network},
  issn = {2577-7270},
  doi = {10.32674/ty3mzc26},
  abstract = {Studentification is a process of neighborhood change characterized by the inmigration of postsecondary students. While studentification is generally conceptualized in the literature as an organic process tied to shifts toward mass higher education participation, I argue universities are not powerless actors in development. They have some degree of control over student residential patterns through university-led urban development initiatives, known as anchor institution initiatives. Utilizing US decennial census data from 1970 to 2010, I employ an inverse probability weighting difference-in-differences model to estimate the effect of anchor initiatives on rates of studentification. Results show a positive effect on studentification in neighborhoods targeted by an anchor initiative. I also find a positive relationship between studentification and rent prices.},
  keywords = {AI:Universities,Economic development,Education Higher,South Africa,United Kingdom,United States}
}

@incollection{harkavyHistoryDevelopmentPartnership2016,
  title = {The {{History}} and {{Development}} of a {{Partnership Approach}} to {{Improve Schools}}, {{Communities}} and {{Universities}}},
  author = {Harkavy, Ira and Hartley, Matthew and Hodges, Rita Axelroth and Weeks, Joann},
  editor = {{van Veen}, Dolf and Lawson, Hal A.},
  year = 2016,
  pages = {303--321},
  publisher = {Cham: Springer International Publishing},
  address = {Cham},
  doi = {10.1007/978-3-319-25664-1_12},
  abstract = {The compelling, important, and innovative idea of ``university-assisted community schools'' originated at the University of Pennsylvania. Today it is an advanced, international exemplar. The main ideas merit attention and scale-up. For example, universities and other higher education institutions located in challenging urban neighborhoods and rural places have important resources to offer local children, families, communities, schools, and neighborhood organizations, starting with their talented faculty and highly energetic and creative students. These resources position these higher education institutions to serve as anchors and hubs for the kinds of complex, multi-faceted innovations needed to improve community outcomes, as well as mutually beneficial outcomes for the higher education institutions doing this important work. Starting in the mid 1980s, the leader-authors of this chapter and their school and community partners seized this idea and then rolled up their sleeves to make it happen. For example, they pioneered and scaled-up important innovations such as academically-based community service---where professors teach their courses in local community schools and other community settings---while also demonstrating how higher education institutions and leaders of research universities in particular can become transformational agents for beneficial social change. This chapter describes the journey toward this advanced exemplar, including the development of the Netter Center for Community Partnerships, the growth of the international network of university-assisted community schools, and the several awards that nominate this model as an international exemplar.},
  keywords = {AI:Universities,Anchor institution,Area-based initiative,At-risk youths,Community development,Community school,Cradle-to-career pipelines,Engaged university,Partnerships,Service learning},
  file = {/home/darrengarside/snap/zotero-snap/common/Zotero/storage/9QSDGQPL/Harkavy et al. - 2016 - The History and Development of a Partnership Approach to Improve Schools, Communities and Universiti.pdf}
}

