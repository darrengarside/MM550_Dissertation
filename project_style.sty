\lstset{
	language=R,                  % set the language to R
	backgroundcolor=\color{white}, % background color
	basicstyle=\ttfamily\footnotesize, % font style
	keywordstyle=\color{black},     % color of keywords
	commentstyle=\color{green},    % color of comments
	stringstyle=\color{black},       % color of strings
	morekeywords={*,...},          % add extra keywords
	numberstyle=\tiny\color{black}, % line number style
	numbers=left,                 % show line numbers on the left
	stepnumber=1,                 % line number step
	numbersep=5pt,                % space between line numbers and code
	frame=single,                 % add a frame around the code
	rulecolor=\color{black},      % color of the frame
	breaklines=true,              % automatic line breaks
	captionpos=b,                 % position of the caption
	escapeinside={\%*}{*)},       % escape to LaTeX inside code
	morecomment=[l][\color{magenta}]{\#}, % special comment style
}

